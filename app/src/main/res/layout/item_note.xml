<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardNote"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvTitre"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/ivFavori"
            android:ellipsize="end"
            android:maxLines="1"
            android:text="Titre"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#212121"/>

        <ImageView
            android:id="@+id/ivFavori"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@android:drawable/btn_star_big_off"
            android:contentDescription="Favori" />

        <TextView
            android:id="@+id/tvContenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvTitre"
            android:layout_marginTop="4dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Contenu..."
            android:textSize="14sp"
            android:textColor="#616161"/>

        <TextView
            android:id="@+id/tvDate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/tvContenu"
            android:layout_marginTop="6dp"
            android:text="01/01/2026"
            android:textSize="12sp"
            android:textColor="#9E9E9E"/>

    </RelativeLayout>

</androidx.cardview.widget.CardView>